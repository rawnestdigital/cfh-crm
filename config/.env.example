# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cfh_crm
DB_USER=cfh_user
DB_PASSWORD=secure_password_here
DB_CHARSET=utf8mb4
DB_SSL_CA=/etc/ssl/certs/ca.pem

# Application Configuration
APP_ENV=production
APP_DEBUG=false
APP_URL=https://join.comeforhumanity.org
APP_NAME="CFH CRM"
APP_KEY=your_app_key_here

# Security Configuration
CSRF_ENABLED=true
CSRF_TOKEN_LENGTH=32
SESSION_LIFETIME=3600
SESSION_SECURE_COOKIES=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_HASH_COST=12
PASSWORD_EXPIRY_DAYS=90

# File Upload
UPLOAD_DIR=/var/www/secure_uploads
MAX_UPLOAD_SIZE=5242880

# Rate Limiting
RATE_LIMIT_ENABLED=true
LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
API_RATE_LIMIT=60

# Email Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=notifications@example.com
MAIL_PASSWORD=email_password_here
MAIL_FROM_ADDRESS=noreply@join.comeforhumanity.org
MAIL_FROM_NAME="CFH CRM"

# Logging
LOG_LEVEL=error
LOG_FILE=/var/log/cfh-crm/app.log
LOG_ERROR_FILE=/var/log/cfh-crm/error.log
LOG_SECURITY_FILE=/var/log/cfh-crm/security.log

# API Configuration
API_ENABLED=false
API_KEY_REQUIRED=true

# Monitoring
ERROR_REPORTING=true
ERROR_EMAIL=admin@example.com
